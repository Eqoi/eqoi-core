# Eqoi Module Metadata
# High-level native app framework for Dolet.

[info]
name = eqoi
version = 0.3.0
description = Native application framework for Dolet — widgets, theme, app loop. Pure-software renderer via ui + fonts.

[dependencies]
ui = required
input = required

[link.windows]
system_libs = user32, gdi32

