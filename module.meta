# Eqoi Module Metadata
# High-level native app framework for Dolet.
# Owns the window + event pump; widgets on top of ui.

[info]
name = eqoi
version = 0.4.0
description = Native application framework for Dolet — window, widgets, theme, app loop, managed state, responsive panels, and advanced widgets (scrollbar, tabs, dropdown, modal, drag/drop).

[dependencies]
window = required
ui = required
input = required

[link.windows]
system_libs = user32, gdi32

[link.linux]
# Planned later.

[link.macos]
# Planned later.
